# ============================================================
# Game Analytics Pipeline - Environment Variables
# ============================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control!
# ============================================================

# ── AppsFlyer ───────────────────────────────────────
APPSFLYER_API_TOKEN=your_v2_api_token_here
APPSFLYER_APP_ID=com.yourgame.app

# ── Google Cloud Platform ───────────────────────────
GCP_PROJECT_ID=your-gcp-project-id
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# ── BigQuery Datasets ───────────────────────────────
BIGQUERY_DATASET_RAW=game_raw
BIGQUERY_DATASET_STAGING=game_staging
BIGQUERY_DATASET_WAREHOUSE=game_warehouse
BIGQUERY_DATASET_MARTS=game_marts
BIGQUERY_DATASET_ML=game_ml

# ── Google Cloud Storage ────────────────────────────
GCS_DATA_LOCKER_BUCKET=af-datalocker-yourgame
GCS_TEMP_BUCKET=game-analytics-temp

# ── Optional ────────────────────────────────────────
LOG_LEVEL=INFO
